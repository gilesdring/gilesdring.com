---
# What the list is wrapped in
container: ul
# What each item in the list is
item: li
---
<nav class="site">
  <{{ container }} class="no-space">
    {{ for p of search.pages("nav.order!=undefined", "nav.order") }}
    <{{ item }} class="{{ if url == p.url }}current{{ /if }}">
      <a href="{{ p.url }}">{{ p.nav.title || p.title }}</a>
    </{{ item }}>
    {{ /for }}
  </{{ container }}>
</nav>
